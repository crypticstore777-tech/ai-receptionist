# ===================================
# Mysterious Enterprise AI Receptionist
# Environment Variables
# ===================================

# --- LiveKit (Real-time media bridge) ---
# Sign up free: https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# --- OpenAI (LLM - the brain) ---
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# --- Deepgram (Speech-to-Text) ---
# Sign up: https://console.deepgram.com (FREE $200 credit!)
DEEPGRAM_API_KEY=your_deepgram_key

# --- Cartesia (Text-to-Speech voice) ---
# Sign up: https://play.cartesia.ai
CARTESIA_API_KEY=your_cartesia_key
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091

# --- Twilio (Phone number & SIP) ---
# Sign up: https://www.twilio.com (free trial)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
